# ============================================================
# everyone-play-safety API 환경변수 예시
# 실제 값은 .env 파일에 저장하고 .gitignore에 포함할 것
# ============================================================

# === Database (MySQL) ===
DATABASE_URL=mysql+aiomysql://root:CHANGE_ME@localhost:3306/everyoneplay_safety

# === Auth ===
SECRET_KEY=CHANGE_ME_TO_RANDOM_LONG_STRING
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# === YouTube RTMP (송출용, OBS가 직접 사용) ===
YOUTUBE_RTMP_URL=rtmp://a.rtmp.youtube.com/live2

# === SMS (NHN Cloud) ===
NHN_APP_KEY=
NHN_SECRET_KEY=
SMS_SENDER_NUMBER=

# === Google Drive (클립 업로드) ===
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_DRIVE_FOLDER_ID=

# === 클립 저장 경로 ===
CLIP_STORAGE_DIR=/home/weplay/dev/everyone-play-safety/clips

# === Audit 로그 경로 ===
AUDIT_LOG_PATH=/tmp/safety-audit.log
